# Copy to ".env" and fill in. NEVER commit the real .env (it is gitignored).

# From platform.claude.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# From Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The SERVICE ROLE key (secret). It bypasses row-level security so the pipeline
# can insert exercises. Keep it only on your machine — it must never reach the
# browser app or the git repo.
SUPABASE_SERVICE_KEY=eyJ...

# Text-to-speech for the audio clip repository (scripts/generate-audio.mjs)
SPEECHIFY_API_KEY=
# Optional: force one narrator instead of the built-in pool
SPEECHIFY_VOICE_ID=
SPEECHIFY_MODEL=
